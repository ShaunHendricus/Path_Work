#!/usr/bin/env python3
import rclpy
from rclpy.node import Node
from rclpy.clock import Clock
from sensor_msgs.msg import PointCloud2
import sensor_msgs_py.point_cloud2 as pc2
from tf2_ros import Buffer, TransformListener
import tf2_sensor_msgs.tf2_sensor_msgs as tf2_sm
import numpy as np


class VoxelDownsampler(Node):
    def __init__(self):
        super().__init__('voxel_grid_downsampler')

        self.declare_parameter('leaf_size', 0.02)
        self.declare_parameter('input_topic',  '/points/xyzrgba')
        self.declare_parameter('output_topic', '/points_downsampled_world')
        self.declare_parameter('target_frame', 'world')

        leaf        = self.get_parameter('leaf_size').value
        in_topic    = self.get_parameter('input_topic').value
        out_topic   = self.get_parameter('output_topic').value
        self.target = self.get_parameter('target_frame').value

        self.leaf_size = leaf

        self.tf_buffer   = Buffer()
        self.tf_listener = TransformListener(self.tf_buffer, self)

        self.pub = self.create_publisher(PointCloud2, out_topic, 10)
        self.pub_raw = self.create_publisher(PointCloud2, out_topic + '_raw', 10)
        self.sub = self.create_subscription(PointCloud2, in_topic, self.callback, 10)
        self.get_logger().info(f'   Downsampler initialized:')
        self.get_logger().info(f'   Input:  {in_topic}')
        self.get_logger().info(f'   Output: {out_topic}')
        self.get_logger().info(f'   Target frame: {self.target}')
        self.get_logger().info(f'   Leaf size: {self.leaf_size}m')
        self.get_logger().info(f'   Waiting for TF tree to stabilize...')

    def callback(self, msg: PointCloud2):
        # Use latest available transform, not the cloud's timestamp
        try:
            transform = self.tf_buffer.lookup_transform(
                self.target,
                msg.header.frame_id,
                rclpy.time.Time(),  # Gets latest transform
                timeout=rclpy.duration.Duration(seconds=0.1)
            )
            msg = tf2_sm.do_transform_cloud(msg, transform)
            self.get_logger().debug(f'Transformed cloud from [{msg.header.frame_id}] → [{self.target}]')
        except Exception as e:
            self.get_logger().error(
                f'TF lookup FAILED: Cannot transform from [{msg.header.frame_id}] → [{self.target}]. '
                f'Available frames? Check TF tree with: ros2 run tf2_tools view_frames. Error: {e}'
            )
            return

        # Set a valid timestamp for RViz display
        msg.header.stamp = Clock().now().to_msg()
        
        # Publish raw transformed cloud for debugging
        self.pub_raw.publish(msg)

        # Read all points with available fields (including color if present)
        points = pc2.read_points(msg, skip_nans=True)
        points_list = list(points)
        
        if len(points_list) == 0:
            return

        # Voxel downsampling using numpy
        points_arr = np.array([(p[0], p[1], p[2]) for p in points_list], dtype=np.float32)
        
        ls = self.leaf_size
        voxel_idx = np.floor(points_arr / ls).astype(np.int32)
        
        # For each unique voxel, keep the first point (preserves color)
        _, unique_indices = np.unique(voxel_idx, axis=0, return_index=True)
        unique_indices = np.sort(unique_indices)
        downsampled_points = [points_list[i] for i in unique_indices]
        
        # Create output cloud - preserve original fields if present
        out = pc2.create_cloud(msg.header, msg.fields, downsampled_points)
        self.pub.publish(out)
        self.get_logger().info(f'Published {len(downsampled_points)} pts (from {len(points_list)}) in [{self.target}]',
                               throttle_duration_sec=2.0)


def main(args=None):
    rclpy.init(args=args)
    node = VoxelDownsampler()
    rclpy.spin(node)
    rclpy.shutdown()


if __name__ == '__main__':
    main()